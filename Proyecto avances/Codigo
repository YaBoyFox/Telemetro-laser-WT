#include <Wire.h>
#include <Adafruit_VL53L0X.h>
#include <SoftwareSerial.h>


Adafruit_VL53L0X lox = Adafruit_VL53L0X();


SoftwareSerial miBluetooth(10, 11); 

void setup() {
  Serial.begin(9600);
  miBluetooth.begin(9600); 

  Serial.println("Iniciando Telémetro...");
  
 
  delay(500); 


  if (!lox.begin()) {
    Serial.println(F("Error: No se detectó el VL53L0X"));
    while (1);
  }

  Serial.println(F("Sensor VL53L0X detectado y listo."));
  miBluetooth.println("Sistema Listo. Envia 'M' para medir.");
}

void loop() {
 
  if (miBluetooth.available()) {
    char comando = miBluetooth.read();
    
   
    if (comando == 'M' || comando == 'm') {
      
      VL53L0X_RangingMeasurementData_t measure;
      
     
      lox.rangingTest(&measure, false); 

     
      if (measure.RangeStatus != 4) {  
        miBluetooth.print("Distancia: ");
        miBluetooth.print(measure.RangeMilliMeter);
        miBluetooth.println(" mm");
      } else {
        miBluetooth.println("Fuera de rango (Demasiado lejos o sin objeto)");
      }
    }
  }
}
